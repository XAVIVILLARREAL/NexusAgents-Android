<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NexusAgents" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryDark">@color/bg_deep</item>
        <item name="colorAccent">@color/neon_magenta</item>
        <item name="colorOnPrimary">@color/bg_void</item>
        <item name="android:colorBackground">@color/bg_void</item>
        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/nav_bg</item>
        <item name="android:windowBackground">@color/bg_void</item>
        <item name="android:textColorPrimary">@color/text_neon</item>
        <item name="android:textColorSecondary">@color/text_dim</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:navigationBarDividerColor">@android:color/transparent</item>
        <item name="colorControlHighlight">@color/glass_cyan</item>
    </style>

    <style name="Widget.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/nav_bg</item>
        <item name="itemIconTint">@color/nav_selector</item>
        <item name="itemTextColor">@color/nav_selector</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">0dp</item>
    </style>
</resources>
