<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema principal — oscuro profesional -->
    <style name="Theme.NexusAgents" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorOnPrimary">@color/bg_terminal</item>
        <item name="android:colorBackground">@color/bg_terminal</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/nav_bg</item>
        <item name="android:windowBackground">@color/bg_terminal</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:navigationBarDividerColor">@android:color/transparent</item>
        
        <!-- Animaciones -->
        <item name="android:windowAnimationStyle">@style/WindowAnimations</item>
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
        
        <!-- Ripple -->
        <item name="colorControlHighlight">@color/primary</item>
    </style>

    <!-- Animaciones de ventana -->
    <style name="WindowAnimations">
        <item name="android:windowEnterAnimation">@anim/slide_in_right</item>
        <item name="android:windowExitAnimation">@anim/slide_out_left</item>
    </style>

    <!-- Tema Splash Screen -->
    <style name="Theme.Splash" parent="Theme.NexusAgents">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@color/splash_bg</item>
    </style>

    <!-- BottomNavigation personalizado -->
    <style name="Widget.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/nav_bg</item>
        <item name="itemIconTint">@color/nav_selector</item>
        <item name="itemTextColor">@color/nav_selector</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">0dp</item>
    </style>
</resources>
