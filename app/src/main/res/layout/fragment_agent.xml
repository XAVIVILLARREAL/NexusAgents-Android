<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_void">

    <!-- Barra de acento neón (color del agente) -->
    <View
        android:id="@+id/accentBar"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/neon_cyan" />

    <!-- Status bar: agente · sesión · zoom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:gravity="center_vertical"
        android:background="@color/bg_deep">

        <TextView
            android:id="@+id/statusLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🧠 DeepSeek · Sesión 1"
            android:textColor="@color/text_neon"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/zoomLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100%"
            android:textColor="@color/neon_cyan"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btnNotes"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_notes"
            android:background="?selectableItemBackgroundBorderless"
            android:tint="@color/neon_cyan"
            android:contentDescription="Notas" />
    </LinearLayout>

    <!-- Chips de sesiones -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:background="@color/bg_deep">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/sessionChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacing="4dp" />
    </HorizontalScrollView>

    <!-- Contenedor WebView -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:id="@+id/webViewContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Copy/Paste floating buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:orientation="horizontal"
            android:elevation="8dp">

            <ImageButton
                android:id="@+id/btnCopy"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_copy"
                android:background="@drawable/bg_zoom_bar"
                android:tint="@color/neon_cyan"
                android:contentDescription="Copiar" />

            <ImageButton
                android:id="@+id/btnPaste"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_paste"
                android:background="@drawable/bg_zoom_bar"
                android:tint="@color/neon_magenta"
                android:layout_marginStart="4dp"
                android:contentDescription="Pegar" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_gravity="top"
            android:indeterminate="true"
            android:indeterminateTint="@color/neon_cyan"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Barra de ZOOM persistente con glassmorphism -->
    <LinearLayout
        android:id="@+id/zoomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_zoom_bar"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="4dp"
        android:elevation="8dp">

        <!-- Botón zoom out -->
        <ImageButton
            android:id="@+id/btnZoomOut"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_zoom_out"
            android:background="?selectableItemBackgroundBorderless"
            android:tint="@color/text_neon"
            android:contentDescription="Zoom out" />

        <!-- Slider de zoom -->
        <SeekBar
            android:id="@+id/zoomSlider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="65"
            android:progress="20"
            android:thumb="@drawable/slider_thumb"
            android:progressTint="@color/neon_cyan"
            android:thumbTint="@color/neon_cyan"
            android:paddingHorizontal="4dp" />

        <!-- Botón zoom in -->
        <ImageButton
            android:id="@+id/btnZoomIn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_zoom_in"
            android:background="?selectableItemBackgroundBorderless"
            android:tint="@color/text_neon"
            android:contentDescription="Zoom in" />

        <!-- Presets -->
        <TextView
            android:id="@+id/zoomPreset100"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1x"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:paddingHorizontal="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/zoomPreset150"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.5x"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:paddingHorizontal="6dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Botón reset -->
        <ImageButton
            android:id="@+id/btnZoomReset"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_zoom_reset"
            android:background="?selectableItemBackgroundBorderless"
            android:tint="@color/neon_magenta"
            android:contentDescription="Reset" />
    </LinearLayout>

</LinearLayout>
