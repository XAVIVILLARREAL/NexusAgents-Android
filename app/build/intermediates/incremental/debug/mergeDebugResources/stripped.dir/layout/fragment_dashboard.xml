<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_void"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📊 Server Dashboard"
                android:textColor="@color/neon_cyan"
                android:textSize="18sp"
                android:textStyle="bold" />
            <ImageButton
                android:id="@+id/btnRefresh"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_zoom_reset"
                android:background="?selectableItemBackgroundBorderless"
                android:tint="@color/neon_cyan" />
        </LinearLayout>

        <!-- RAM Bar -->
        <TextView
            android:id="@+id/ramText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RAM: -- / -- MB"
            android:textColor="@color/text_neon"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:paddingBottom="4dp" />
        <ProgressBar
            android:id="@+id/ramBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Uptime -->
        <TextView
            android:id="@+id/uptimeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Uptime: --"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingBottom="16dp" />

        <!-- Container status cards -->
        <LinearLayout
            android:id="@+id/statusCards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>
