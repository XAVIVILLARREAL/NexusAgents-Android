<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="accent">#FF448AFF</color>
    <color name="bg_surface">#FF0E0E12</color>
    <color name="bg_terminal">#FF080808</color>
    <color name="chip_bg_selected">#22FFFFFF</color>
    <color name="divider">#1AFFFFFF</color>
    <color name="divider_strong">#22FFFFFF</color>
    <color name="nav_active">#FFFFFFFF</color>
    <color name="nav_bg">#FF0A0A10</color>
    <color name="nav_inactive">#FF5A5A6E</color>
    <color name="primary">#FF00E676</color>
    <color name="primary_dark">#FF00C853</color>
    <color name="splash_accent">#FF00E676</color>
    <color name="splash_bg">#FF080808</color>
    <color name="surface_card">#E614141C</color>
    <color name="surface_dark">#FF16161E</color>
    <color name="surface_light">#FF1E1E2A</color>
    <color name="text_dim">#FF60606E</color>
    <color name="text_primary">#FFE8E8EC</color>
    <color name="text_secondary">#FF9A9AA8</color>
    <string name="antigravity_desc">Antigravity CLI</string>
    <string name="app_name">Nexus Agents</string>
    <string name="background_notification_text">Herramientas activas — programando en segundo plano</string>
    <string name="background_notification_title">Nexus Agents</string>
    <string name="codex_desc">Codex CLI</string>
    <string name="deepseek_desc">DeepSeek TUI / CodeWhale</string>
    <string name="gemini_desc">Google Gemini CLI</string>
    <string name="minimax_desc">Minimax CLI</string>
    <style name="Theme.NexusAgents" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorOnPrimary">@color/bg_terminal</item>
        <item name="android:colorBackground">@color/bg_terminal</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/nav_bg</item>
        <item name="android:windowBackground">@color/bg_terminal</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:navigationBarDividerColor">@android:color/transparent</item>
        
        
        <item name="android:windowAnimationStyle">@style/WindowAnimations</item>
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
        
        
        <item name="colorControlHighlight">@color/primary</item>
    </style>
    <style name="Theme.Splash" parent="Theme.NexusAgents">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@color/splash_bg</item>
    </style>
    <style name="Widget.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/nav_bg</item>
        <item name="itemIconTint">@color/nav_selector</item>
        <item name="itemTextColor">@color/nav_selector</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">0dp</item>
    </style>
    <style name="WindowAnimations">
        <item name="android:windowEnterAnimation">@anim/slide_in_right</item>
        <item name="android:windowExitAnimation">@anim/slide_out_left</item>
    </style>
</resources>